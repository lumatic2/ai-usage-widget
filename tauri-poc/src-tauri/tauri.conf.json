{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Usage Widget",
  "version": "0.1.1",
  "identifier": "com.lumatic2.ai-usage-widget",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Usage Widget",
        "width": 780,
        "height": 320,
        "minWidth": 380,
        "minHeight": 220,
        "x": 40,
        "y": 40,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "shadow": false,
        "skipTaskbar": true,
        "backgroundColor": "#00000000",
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
