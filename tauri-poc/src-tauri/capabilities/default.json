{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main widget and the agent-office window",
  "windows": ["main", "agent_office"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging",
    "opener:default",
    "notification:default",
    "autostart:default"
  ]
}
